<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Gosloto" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorPrimaryVariant">@color/blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/blue_bg</item>
        <item name="android:statusBarColor">@color/blue_dark</item>
    </style>

    <style name="Theme.Splash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="android:statusBarColor">@color/blue_dark</item>
    </style>

    <style name="AppBar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/blue_primary</item>
        <item name="titleTextColor">@color/white</item>
    </style>

    <style name="AppBar.Red">
        <item name="android:background">@color/red_primary</item>
    </style>
    <style name="AppBar.Green">
        <item name="android:background">@color/green_primary</item>
    </style>
    <style name="AppBar.Purple">
        <item name="android:background">@color/purple_primary</item>
    </style>
    <style name="AppBar.Orange">
        <item name="android:background">@color/orange_primary</item>
    </style>
    <style name="AppBar.Navy">
        <item name="android:background">@color/navy_primary</item>
    </style>
    <style name="AppBar.Teal">
        <item name="android:background">@color/teal_primary</item>
    </style>
</resources>
